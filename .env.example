# Optional bootstrap config.
#
# Qdrant is normally configured in the app's Settings tab (stored in
# app_config.json). These two values are only used to pre-fill the very first
# "default" connection on first run — you can leave them blank and add a
# connection from the UI instead.
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_KEY=your-qdrant-api-key

# Where temporary uploads are staged on disk.
UPLOAD_DIR=/tmp/store_check_uploads
