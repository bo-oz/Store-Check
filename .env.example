# Qdrant connection (also editable at runtime in the Settings tab)
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_KEY=your-qdrant-api-key
QDRANT_COLLECTION=retail_shelf_analytics_dinov2

# DINOv2 embedding model (timm key) and its vector dimension — keep these in sync.
#   vit_small_patch14_dinov2.lvd142m  -> 384
#   vit_base_patch14_dinov2.lvd142m   -> 768
#   vit_large_patch14_dinov2.lvd142m  -> 1024
DINOV2_MODEL=vit_small_patch14_dinov2.lvd142m
EMBED_DIM=384

# Where temporary uploads are staged
UPLOAD_DIR=/tmp/store_check_uploads
